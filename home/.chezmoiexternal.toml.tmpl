# External dependencies fetched by `chezmoi apply`.
#
#   - archive:                       shell/editor plugins as pinned tarballs.
#   - file / archive-file:           binaries from GitHub releases or
#                                    dl.k8s.io. Cross-platform via
#                                    .chezmoi.os / .chezmoi.arch.

# --- Plugins (pinned release tarballs) -----------------------------------
# Pinned to fixed tags/commits and fetched as archives. `git-repo` externals
# trip over each other on a fresh box when none of the target dirs exist
# yet, so we trade rolling HEAD for deterministic, single-shot installs.
# Bump the version/sha here when an update is wanted.

[".zsh/plugins/zsh-autosuggestions"]
    type = "archive"
    url = "https://github.com/zsh-users/zsh-autosuggestions/archive/refs/tags/v0.7.1.tar.gz"
    stripComponents = 1
    exact = true
    refreshPeriod = "168h"

[".tmux/plugins/tpm"]
    type = "archive"
    url = "https://github.com/tmux-plugins/tpm/archive/refs/tags/v3.1.0.tar.gz"
    stripComponents = 1
    exact = true
    refreshPeriod = "168h"

# --- Binaries (release downloads) ---------------------------------------
# Naming conventions vary per tool. Map .chezmoi.os/.arch to each.

{{- $arch := "x86_64" -}}
{{- if eq .chezmoi.arch "arm64" -}}{{- $arch = "aarch64" -}}{{- end -}}

# Rust target. Linux x86_64 release artifacts are musl; arm64 is gnu-only.
{{- $rustTarget := "" -}}
{{- if eq .chezmoi.os "darwin" -}}
{{-   $rustTarget = printf "%s-apple-darwin" $arch -}}
{{- else if eq .chezmoi.os "linux" -}}
{{-   if eq .chezmoi.arch "amd64" -}}
{{-     $rustTarget = "x86_64-unknown-linux-musl" -}}
{{-   else -}}
{{-     $rustTarget = "aarch64-unknown-linux-gnu" -}}
{{-   end -}}
{{- end }}

# nvim — full distribution (binary needs lib/ + share/ siblings, lives
# in ~/.local/opt/nvim and is added to PATH by dot_shell.env).
{{- $nvimOs := .chezmoi.os -}}
{{- if eq $nvimOs "darwin" -}}{{- $nvimOs = "macos" -}}{{- end -}}
{{- $nvimArch := "x86_64" -}}
{{- if eq .chezmoi.arch "arm64" -}}{{- $nvimArch = "arm64" -}}{{- end }}

[".local/opt/nvim"]
    type = "archive"
    url = {{ gitHubLatestReleaseAssetURL "neovim/neovim" (printf "nvim-%s-%s.tar.gz" $nvimOs $nvimArch) | quote }}
    stripComponents = 1
    exact = true
    refreshPeriod = "168h"

# starship — flat archive (binary at archive root).
{{ if $rustTarget -}}
[".local/bin/starship"]
    type = "archive-file"
    url = {{ gitHubLatestReleaseAssetURL "starship/starship" (printf "starship-%s.tar.gz" $rustTarget) | quote }}
    executable = true
    path = "starship"
    refreshPeriod = "168h"
{{- end }}

# ripgrep — versioned dir; derive its name from the asset URL so we can
# point archive-file at the binary inside without globbing.
{{ if $rustTarget -}}
{{- $rgUrl := gitHubLatestReleaseAssetURL "BurntSushi/ripgrep" (printf "ripgrep-*-%s.tar.gz" $rustTarget) -}}
{{- $rgDir := trimSuffix ".tar.gz" (base $rgUrl) }}
[".local/bin/rg"]
    type = "archive-file"
    url = {{ $rgUrl | quote }}
    executable = true
    path = "{{ $rgDir }}/rg"
    refreshPeriod = "168h"
{{- end }}

# fd — same pattern.
{{ if $rustTarget -}}
{{- $fdUrl := gitHubLatestReleaseAssetURL "sharkdp/fd" (printf "fd-v*-%s.tar.gz" $rustTarget) -}}
{{- $fdDir := trimSuffix ".tar.gz" (base $fdUrl) }}
[".local/bin/fd"]
    type = "archive-file"
    url = {{ $fdUrl | quote }}
    executable = true
    path = "{{ $fdDir }}/fd"
    refreshPeriod = "168h"
{{- end }}

# bat — same pattern.
{{ if $rustTarget -}}
{{- $batUrl := gitHubLatestReleaseAssetURL "sharkdp/bat" (printf "bat-v*-%s.tar.gz" $rustTarget) -}}
{{- $batDir := trimSuffix ".tar.gz" (base $batUrl) }}
[".local/bin/bat"]
    type = "archive-file"
    url = {{ $batUrl | quote }}
    executable = true
    path = "{{ $batDir }}/bat"
    refreshPeriod = "168h"
{{- end }}

# fzf — flat tarball with a single binary.
[".local/bin/fzf"]
    type = "archive-file"
    url = {{ gitHubLatestReleaseAssetURL "junegunn/fzf" (printf "fzf-*-%s_%s.tar.gz" .chezmoi.os .chezmoi.arch) | quote }}
    executable = true
    path = "fzf"
    refreshPeriod = "168h"

# kubectl — pinned to whatever dl.k8s.io says is current stable.
{{ $kubectlVersion := output "curl" "-fsSL" "https://dl.k8s.io/release/stable.txt" | trim -}}
[".local/bin/kubectl"]
    type = "file"
    url = {{ printf "https://dl.k8s.io/release/%s/bin/%s/%s/kubectl" $kubectlVersion .chezmoi.os .chezmoi.arch | quote }}
    executable = true
    refreshPeriod = "168h"

# kind — single binary asset.
[".local/bin/kind"]
    type = "file"
    url = {{ gitHubLatestReleaseAssetURL "kubernetes-sigs/kind" (printf "kind-%s-%s" .chezmoi.os .chezmoi.arch) | quote }}
    executable = true
    refreshPeriod = "168h"

# k9s — capitalised OS in asset name (Darwin/Linux).
{{ $k9sOs := title .chezmoi.os -}}
[".local/bin/k9s"]
    type = "archive-file"
    url = {{ gitHubLatestReleaseAssetURL "derailed/k9s" (printf "k9s_%s_%s.tar.gz" $k9sOs .chezmoi.arch) | quote }}
    executable = true
    path = "k9s"
    refreshPeriod = "168h"
