# External dependencies fetched by `chezmoi apply`.
#
#   - archive:                       shell/editor plugins as pinned tarballs.
#   - file / archive-file:           binaries from GitHub releases or
#                                    dl.k8s.io. Cross-platform via
#                                    .chezmoi.os / .chezmoi.arch.

# --- Plugins (pinned release tarballs) -----------------------------------
# Pinned to fixed tags/commits and fetched as archives. `git-repo` externals
# trip over each other on a fresh box when none of the target dirs exist
# yet, so we trade rolling HEAD for deterministic, single-shot installs.
# Bump the version/sha here when an update is wanted.

[".zsh/plugins/zsh-autosuggestions"]
    type = "archive"
    url = "https://github.com/zsh-users/zsh-autosuggestions/archive/refs/tags/v0.7.1.tar.gz"
    stripComponents = 1
    exact = true
    refreshPeriod = "168h"

[".tmux/plugins/tpm"]
    type = "archive"
    url = "https://github.com/tmux-plugins/tpm/archive/refs/tags/v3.1.0.tar.gz"
    stripComponents = 1
    exact = true
    refreshPeriod = "168h"

# --- Binaries (release downloads) ---------------------------------------
# Pinned versions instead of `gitHubLatestReleaseAssetURL` so a fresh
# `chezmoi apply` makes zero GitHub API calls. The unauthenticated limit
# is 60/hr — one apply with `latest` lookups burns ~8 of them and a
# freshly-provisioned VM that retries a few times can lock itself out
# for ~hour. Bump versions below by hand (or via a bump script).
# Naming conventions vary per tool; OS/arch mapping is below.

{{- $arch := "x86_64" -}}
{{- if eq .chezmoi.arch "arm64" -}}{{- $arch = "aarch64" -}}{{- end -}}

# Rust target. Linux x86_64 release artifacts are musl; arm64 is gnu-only.
{{- $rustTarget := "" -}}
{{- if eq .chezmoi.os "darwin" -}}
{{-   $rustTarget = printf "%s-apple-darwin" $arch -}}
{{- else if eq .chezmoi.os "linux" -}}
{{-   if eq .chezmoi.arch "amd64" -}}
{{-     $rustTarget = "x86_64-unknown-linux-musl" -}}
{{-   else -}}
{{-     $rustTarget = "aarch64-unknown-linux-gnu" -}}
{{-   end -}}
{{- end -}}

# Pinned versions — bump these to update.
{{- $nvimVersion      := "v0.12.2" -}}
{{- $starshipVersion  := "v1.25.1" -}}
{{- $ripgrepVersion   := "15.1.0"  -}}
{{- $fdVersion        := "v10.4.2" -}}
{{- $batVersion       := "v0.26.1" -}}
{{- $fzfVersion       := "v0.72.0" -}}
{{- $kindVersion      := "v0.31.0" -}}
{{- $k9sVersion       := "v0.50.18" -}}
{{- $mpSkillsRev      := "5d78bd0903420f97c791f834201e550c765699f8" -}}

# nvim — full distribution (binary needs lib/ + share/ siblings, lives
# in ~/.local/opt/nvim and is added to PATH by dot_shell.env).
{{- $nvimOs := .chezmoi.os -}}
{{- if eq $nvimOs "darwin" -}}{{- $nvimOs = "macos" -}}{{- end -}}
{{- $nvimArch := "x86_64" -}}
{{- if eq .chezmoi.arch "arm64" -}}{{- $nvimArch = "arm64" -}}{{- end }}

[".local/opt/nvim"]
    type = "archive"
    url = {{ printf "https://github.com/neovim/neovim/releases/download/%s/nvim-%s-%s.tar.gz" $nvimVersion $nvimOs $nvimArch | quote }}
    stripComponents = 1
    exact = true
    refreshPeriod = "168h"

# starship — flat archive (binary at archive root).
{{ if $rustTarget -}}
[".local/bin/starship"]
    type = "archive-file"
    url = {{ printf "https://github.com/starship/starship/releases/download/%s/starship-%s.tar.gz" $starshipVersion $rustTarget | quote }}
    executable = true
    path = "starship"
    refreshPeriod = "168h"
{{- end }}

# ripgrep — versioned dir; build its name from the pinned version so
# archive-file can point at the binary inside without globbing.
{{ if $rustTarget -}}
{{- $rgDir := printf "ripgrep-%s-%s" $ripgrepVersion $rustTarget }}
[".local/bin/rg"]
    type = "archive-file"
    url = {{ printf "https://github.com/BurntSushi/ripgrep/releases/download/%s/%s.tar.gz" $ripgrepVersion $rgDir | quote }}
    executable = true
    path = "{{ $rgDir }}/rg"
    refreshPeriod = "168h"
{{- end }}

# fd — same pattern.
{{ if $rustTarget -}}
{{- $fdDir := printf "fd-%s-%s" $fdVersion $rustTarget }}
[".local/bin/fd"]
    type = "archive-file"
    url = {{ printf "https://github.com/sharkdp/fd/releases/download/%s/%s.tar.gz" $fdVersion $fdDir | quote }}
    executable = true
    path = "{{ $fdDir }}/fd"
    refreshPeriod = "168h"
{{- end }}

# bat — same pattern.
{{ if $rustTarget -}}
{{- $batDir := printf "bat-%s-%s" $batVersion $rustTarget }}
[".local/bin/bat"]
    type = "archive-file"
    url = {{ printf "https://github.com/sharkdp/bat/releases/download/%s/%s.tar.gz" $batVersion $batDir | quote }}
    executable = true
    path = "{{ $batDir }}/bat"
    refreshPeriod = "168h"
{{- end }}

# fzf — flat tarball with a single binary. Asset name drops the leading
# "v" from the tag.
{{- $fzfAssetVersion := trimPrefix "v" $fzfVersion }}
[".local/bin/fzf"]
    type = "archive-file"
    url = {{ printf "https://github.com/junegunn/fzf/releases/download/%s/fzf-%s-%s_%s.tar.gz" $fzfVersion $fzfAssetVersion .chezmoi.os .chezmoi.arch | quote }}
    executable = true
    path = "fzf"
    refreshPeriod = "168h"

# kubectl — pinned to whatever dl.k8s.io says is current stable. Not on
# GitHub so it doesn't count against the rate limit.
{{ $kubectlVersion := output "curl" "-fsSL" "https://dl.k8s.io/release/stable.txt" | trim -}}
[".local/bin/kubectl"]
    type = "file"
    url = {{ printf "https://dl.k8s.io/release/%s/bin/%s/%s/kubectl" $kubectlVersion .chezmoi.os .chezmoi.arch | quote }}
    executable = true
    refreshPeriod = "168h"

# kind — single binary asset.
[".local/bin/kind"]
    type = "file"
    url = {{ printf "https://github.com/kubernetes-sigs/kind/releases/download/%s/kind-%s-%s" $kindVersion .chezmoi.os .chezmoi.arch | quote }}
    executable = true
    refreshPeriod = "168h"

# k9s — capitalised OS in asset name (Darwin/Linux).
{{ $k9sOs := title .chezmoi.os -}}
[".local/bin/k9s"]
    type = "archive-file"
    url = {{ printf "https://github.com/derailed/k9s/releases/download/%s/k9s_%s_%s.tar.gz" $k9sVersion $k9sOs .chezmoi.arch | quote }}
    executable = true
    path = "k9s"
    refreshPeriod = "168h"

# --- Claude Code skills (vendored from upstream) ------------------------
# Each skill lands in ~/.claude/skills/<name>/ as its own archive external.
# Skill repos are laid out differently, so url/include/stripComponents are
# per-entry, not global. Entries sharing a url are fetched once and served
# from cache, so many skills from one repo cost one download.
#
# mattpocock/skills: pinned by commit SHA ($mpSkillsRev above) — upstream
# cuts no tags. Layout is skills-<sha>/skills/<category>/<name>/, so
# stripComponents = 4 drops those levels and the skill's files land
# directly under the target. The list below loops to one external each;
# add a skill by appending {name, category}, bump $mpSkillsRev to update.
{{- $mpUrl := printf "https://github.com/mattpocock/skills/archive/%s.tar.gz" $mpSkillsRev -}}
{{- $mpSkills := list

      (dict "name" "grill-me"                      "category" "productivity")
      (dict "name" "handoff"                       "category" "productivity")
      (dict "name" "writing-great-skills"          "category" "productivity")

      (dict "name" "codebase-design"               "category" "engineering")
      (dict "name" "domain-modeling"               "category" "engineering")
      (dict "name" "grill-with-docs"               "category" "engineering")
      (dict "name" "improve-codebase-architecture" "category" "engineering")
      (dict "name" "prototype"                     "category" "engineering")
      (dict "name" "tdd"                           "category" "engineering")
-}}
{{ range $mpSkills }}
[".claude/skills/{{ .name }}"]
    type = "archive"
    url = {{ $mpUrl | quote }}
    include = ["{{ printf "**/skills/%s/%s/**" .category .name }}"]
    stripComponents = 4
    exact = true
    refreshPeriod = "168h"
{{ end }}
# Skills from other repos: add explicit blocks here. They will not share
# the mattpocock layout, so set url/include/stripComponents to match that
# repo's tarball (one block per skill, same shape as the externals above).

# cloudflare/security-audit-skill: SKILL.md and its supporting files sit at
# the tarball root, so stripComponents = 1 lands them directly under the
# target. Pinned by commit SHA — upstream cuts no tags, and archive-by-SHA
# makes zero GitHub API calls (same reasoning as the binaries above). Dir
# matches the in-skill name "security-audit"; bump the SHA to update.
{{- $sasRev := "4de1ac80123057dd73c586cd3862a6c85a2b8a5e" }}
[".claude/skills/security-audit"]
    type = "archive"
    url = {{ printf "https://github.com/cloudflare/security-audit-skill/archive/%s.tar.gz" $sasRev | quote }}
    stripComponents = 1
    exact = true
    refreshPeriod = "168h"
