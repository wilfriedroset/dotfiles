# This file is meant to be used by both bash and zsh in an attempt to make both
# coexist as much as possible.
#
# Loaded:
#   - zsh non-interactive shells via ~/.zshenv (subprocesses, IDEs)
#   - interactive shells via shell.rc
# Keep this file env-only and idempotent: no aliases, no shell options that
# would misbehave on re-source.

export LANG=en_US.UTF-8

EDITOR=vim
if command -v nvim >/dev/null 2>&1; then
  EDITOR=nvim
fi
export EDITOR

# OSX specific
if [[ "$OSTYPE" == "darwin"* ]]; then
    # let's install app using brew cask in user space
    export HOMEBREW_CASK_OPTS="--appdir=${HOME}/Applications"
fi

[ -f "${HOME}/.shell.env.local" ] && source "${HOME}/.shell.env.local"

# nvim from chezmoi external lives in ~/.local/opt/nvim because the binary
# needs sibling lib/ and share/ dirs at runtime. Single-binary tools land
# directly in ~/.local/bin. Both prepended idempotently.
for _opt in \
    "${HOME}/.local/opt/nvim/bin" \
    "${HOME}/.local/bin"; do
    case ":${PATH}:" in
        *":${_opt}:"*) ;;
        *) PATH="${_opt}:${PATH}" ;;
    esac
done
unset _opt
export PATH

# Bump the soft fd limit once per process tree.
if [ -z "${_DOTFILES_ULIMIT_DONE:-}" ]; then
    ulimit -n 10240 2>/dev/null
    export _DOTFILES_ULIMIT_DONE=1
fi

export K9S_CONFIG_DIR="${HOME}/.config/k9s"
